# Loom session-learning — nightly weave to loom-shadow (review then `loom promote`)
# Runs from the dedicated runtime clone (loom/setup-runtime.sh provisions ~/loom-runtime),
# NOT the shared dev checkout, so a concurrent session flipping branches can't swap loom's
# code out mid-run. Logs/state stay in the shared repo. Run setup-runtime.sh once first.
CRON_TZ=Europe/Lisbon
0 2 * * *  /home/dev/loom-runtime/loom/run-absorb.sh  >> /home/dev/projects/build-ai-automation-workflow/loom/logs/cron.log 2>&1
